# Database
DATABASE_URL=postgres://skills_obs:dev_password@localhost:5432/skills_obs

# JWT secrets (HS256)
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_SECRET_PREVIOUS=

# Admin bootstrap (used only if the users table is empty at startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_INITIAL=admin

# Public base URL (optional — used to lock CORS to a single origin and to render
# onboarding instructions). When unset, the app derives the base URL from the
# incoming request (Host / X-Forwarded-* headers), so it works on any URL out
# of the box. Set this in production to restrict CORS to your public origin.
PUBLIC_BASE_URL=

# SMTP (optional — UI banner only if absent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Server
PORT=4200
NODE_ENV=development
